# Optional: ключ для расширенной интерпретации через LLM
GROQ_API_KEY=

# Demo mode:
# true  -> быстрый детерминированный режим без зависимости от OSM
# false -> разрешить внешние lookup-сервисы при ENABLE_OSM_LOOKUP=true
DEMO_MODE=true

# Внешние геосервисы (Overpass/Nominatim)
ENABLE_OSM_LOOKUP=false

# Расширенная интерпретация через LLM
ENABLE_LLM=true

# Порт uvicorn
PORT=8000
